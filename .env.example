# API
APP_NAME="GraphHarness"
APP_ENV=local
API_KEY_NAME=x-api-key
# Optional. When set, all non-health endpoints require this header value.
LLM_API_KEY=

# LiteLLM
# Use `fake` for local no-LLM evals.
LLM_BACKEND=litellm
LLM_FAKE_SCENARIOS_PATH=
# Any LiteLLM-supported model string, for example:
#   openai/gpt-4o-mini
#   azure/my-deployment
#   anthropic/claude-3-5-sonnet-20241022
#   ollama/llama3.1
#   openrouter/anthropic/claude-3.5-sonnet
#   openai/my-local-model with LITELLM_API_BASE
LLM_MODEL=openai/gpt-4o-mini

# Provider API key. Pick one of the two below.
#
# Option A — Direct provider key (OpenAI, Anthropic, Azure, etc.).
#   Used when LLM_MODEL is a direct provider model (e.g. openai/gpt-4o-mini).
LLM_API_KEY_PROVIDER=
#
# Option B — OpenRouter aggregator key.
#   Used when LLM_MODEL starts with `openrouter/` (e.g. openrouter/anthropic/claude-3.5-sonnet).
#   If both are set, this takes precedence for openrouter/* models.
OPENROUTER_API_KEY=

LITELLM_API_BASE=
LITELLM_TEMPERATURE=0
LITELLM_MAX_TOKENS=2048
LITELLM_TIMEOUT_SECONDS=60

# Microsoft Graph application credentials
# Use `mock` for local no-Microsoft-Graph evals.
GRAPH_BACKEND=live
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SCOPES=https://graph.microsoft.com/.default
GRAPH_DEFAULT_API_VERSION=v1.0
GRAPH_TIMEOUT_SECONDS=30

# Agent controls
AGENT_MAX_TURNS=4
AGENT_MAX_TOOL_CALLS=8
AGENT_LLM_RETRIES=2
AGENT_EMPTY_RESPONSE_RETRIES=1
AGENT_REPEATED_TOOL_CALL_LIMIT=2
AGENT_RECOVERY_MAX_ATTEMPTS=1
AGENT_ENABLE_CLARIFICATION_POLICY=true
AGENT_ENABLE_CONTEXT_COMPACTION=true
AGENT_CONTEXT_RECENT_MESSAGES=8
AGENT_CONTEXT_MAX_TOOL_CHARS=1800
AGENT_LOG_TRACE_EVENTS=true
AGENT_PARALLEL_READS=true
AGENT_REQUIRE_MUTATION_CONFIRMATION=true
